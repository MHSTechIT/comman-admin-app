{
  "name": "diabetes-risk-admin-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "cd admin-panel && npm run dev",
    "dev:admin-v2": "cd admin-panel-v2 && npm run dev",
    "dev:backend": "cd admin-panel-v2 && npm run dev:server",
    "dev:all": "concurrently -n root,admin,admin-v2,backend -c blue,green,yellow,magenta \"npm run dev\" \"npm run dev:admin\" \"npm run dev:admin-v2\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.10"
  }
}
